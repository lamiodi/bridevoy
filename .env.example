# ============================================
# BrideVoy — Local Environment Variables
# Copy this file to .env.local and fill in real values.
# Vite only reads vars prefixed with VITE_.
# ============================================

# Public contact info
VITE_BRAND_EMAIL=reservations@bridevoy.com
VITE_BRAND_PHONE_DISPLAY=+234 803 000 0000

# WhatsApp (digits only, no +, no spaces)
VITE_WHATSAPP_NUMBER=2348030000000
VITE_WHATSAPP_MESSAGE=Hello BrideVoy, I would like to inquire about your luxury chauffeur services.

# Socials
VITE_INSTAGRAM_URL=https://instagram.com/bridevoy
VITE_INSTAGRAM_HANDLE=@bridevoy

# Booking delivery: FormSubmit (no signup, unlimited, free).
# The endpoint is auto-built from VITE_BRAND_EMAIL above.
# First submission triggers a one-time confirmation email from
# FormSubmit — click the link to activate. After that, all
# bookings arrive at VITE_BRAND_EMAIL automatically.
# Leave VITE_BRAND_EMAIL empty to fall back to a mailto: handoff.
# (No VITE_FORMSUBMIT_ENDPOINT variable is required.)
